{
  "name": "yaguar-news",
  "version": "1.0.0",
  "description": "SDK de feed de notícias brasileiras para React — categorias, filtros e agendamento automático",
  "author": "Antigravity",
  "license": "MIT",
  "main": "dist/yaguar-news.umd.js",
  "module": "dist/yaguar-news.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/yaguar-news.es.js",
      "require": "./dist/yaguar-news.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:sdk": "vite build --config vite.lib.config.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.8.3",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^5.0.1"
  },
  "dependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "react",
    "news",
    "feed",
    "sdk",
    "brasil",
    "noticias"
  ]
}
